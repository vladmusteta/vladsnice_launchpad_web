# Copy this to .env and adjust as needed.

# Port on which the frontend (nginx) is exposed on the host
FRONTEND_PORT=3000

# Mount your own scripts directory instead of a Docker-managed volume.
# The path must exist on the host before running docker compose up.
# SCRIPTS_DIR=/home/youruser/monitoring-scripts

# Mount your own envs directory (per-environment scripts/logs/inventories).
# ENVS_DIR=/home/youruser/monitoring-envs
