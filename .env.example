# Copy this to .env and adjust as needed.

# Ports exposed on the host
FRONTEND_PORT=5173
BACKEND_PORT=8000

# IP address to bind on the host (default: 0.0.0.0 = all interfaces)
# Set to a specific IP to expose only on that interface, e.g.:
# BIND_IP=192.168.1.10
BIND_IP=0.0.0.0

# Optional: mount your own directories instead of Docker-managed volumes.
# The paths must exist on the host before running docker compose up.
DATA_DIR=./monitoring-data
SCRIPTS_DIR=./monitoring-scripts
ENVS_DIR=./monitoring-envs
LOGS_DIR=./monitoring-logs